-DATASET CSV empty

--

-CASE Issue692RelTableGroupInPredicate
# Reproduction for github issue #692:
# REL TABLE GROUP property IN predicate duplicates rows and omits another endpoint table
# Note: may only reproduce with on-disk (checkpointed) data

-STATEMENT CREATE NODE TABLE File(id STRING, PRIMARY KEY(id));
---- ok
-STATEMENT CREATE NODE TABLE Function(id STRING, PRIMARY KEY(id));
---- ok
-STATEMENT CREATE REL TABLE CodeRelation(FROM File TO Function, FROM Function TO Function, type STRING, confidence DOUBLE);
---- ok

-STATEMENT CREATE (f1:File {id: 'FileA'}), (f2:File {id: 'FileB'}), (fn1:Function {id: 'Function1'}), (fn2:Function {id: 'Function2'});
---- ok

# File -> Function CALLS
-STATEMENT MATCH (f:File {id: 'FileA'}), (fn:Function {id: 'Function1'}) CREATE (f)-[:CodeRelation {type: 'CALLS', confidence: 0.85}]->(fn);
---- ok

# File -> Function DEFINES
-STATEMENT MATCH (f:File {id: 'FileB'}), (fn:Function {id: 'Function1'}) CREATE (f)-[:CodeRelation {type: 'DEFINES', confidence: 1.0}]->(fn);
---- ok

# Function -> Function CALLS
-STATEMENT MATCH (fn1:Function {id: 'Function2'}), (fn2:Function {id: 'Function1'}) CREATE (fn1)-[:CodeRelation {type: 'CALLS', confidence: 0.85}]->(fn2);
---- ok

# Force checkpoint to ensure data is on disk (may be required to reproduce)
-STATEMENT CHECKPOINT;
---- ok

# No predicate test
-STATEMENT MATCH (s)-[r:CodeRelation]->(t) WHERE t.id = 'Function1' RETURN s.id AS src, t.id AS dst, r.type AS type, r.confidence AS conf ORDER BY src, type;
---- 3
FileA|Function1|CALLS|0.850000
FileB|Function1|DEFINES|1.000000
Function2|Function1|CALLS|0.850000

# Equality predicate test
-STATEMENT MATCH (s)-[r:CodeRelation]->(t) WHERE t.id = 'Function1' AND r.type = 'CALLS' RETURN s.id AS src, t.id AS dst, r.type AS type, r.confidence AS conf ORDER BY src;
---- 2
FileA|Function1|CALLS|0.850000
Function2|Function1|CALLS|0.850000

# Single-element IN predicate test (the bug)
-STATEMENT MATCH (s)-[r:CodeRelation]->(t) WHERE t.id = 'Function1' AND r.type IN ['CALLS'] RETURN s.id AS src, t.id AS dst, r.type AS type, r.confidence AS conf ORDER BY src;
---- 2
FileA|Function1|CALLS|0.850000
Function2|Function1|CALLS|0.850000

# Multi-element IN predicate test
-STATEMENT MATCH (s)-[r:CodeRelation]->(t) WHERE t.id = 'Function1' AND r.type IN ['CALLS', 'DEFINES'] RETURN s.id AS src, t.id AS dst, r.type AS type, r.confidence AS conf ORDER BY src, type;
---- 3
FileA|Function1|CALLS|0.850000
FileB|Function1|DEFINES|1.000000
Function2|Function1|CALLS|0.850000

# Explicit source label + single IN test
-STATEMENT MATCH (s:File)-[r:CodeRelation]->(t) WHERE t.id = 'Function1' AND r.type IN ['CALLS'] RETURN s.id AS src, t.id AS dst, r.type AS type, r.confidence AS conf;
---- 1
FileA|Function1|CALLS|0.850000

-STATEMENT MATCH (s:Function)-[r:CodeRelation]->(t) WHERE t.id = 'Function1' AND r.type IN ['CALLS'] RETURN s.id AS src, t.id AS dst, r.type AS type, r.confidence AS conf;
---- 1
Function2|Function1|CALLS|0.850000
